#!/usr/bin/env bash
#
# pre-commit hook: detect secrets staged for commit
# Install: cp .git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# -------------------------------------------------------------------
# Secret patterns (12+)
# -------------------------------------------------------------------
SECRET_PATTERNS=(
  # AWS
  'AKIA[0-9A-Z]{16}'
  'aws_secret_access_key\s*[=:].+'
  # Generic API keys / tokens
  'api[_-]?key\s*[=:]\s*['\''"][A-Za-z0-9_\-]{20,}'
  'api[_-]?secret\s*[=:]\s*['\''"][A-Za-z0-9_\-]{20,}'
  'api[_-]?token\s*[=:]\s*['\''"][A-Za-z0-9_\-]{20,}'
  # Bearer / OAuth tokens
  'bearer\s+[A-Za-z0-9_\-\.]{20,}'
  # Passwords
  'password\s*[=:]\s*['\''"][^\s]{8,}'
  'passwd\s*[=:]\s*['\''"][^\s]{8,}'
  # Private keys (PEM header)
  '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'
  # GitHub / GitLab tokens
  'gh[ps]_[A-Za-z0-9_\-]{36,}'
  'glpat-[A-Za-z0-9_\-]{20,}'
  # Slack tokens
  'xox[boapr]-[A-Za-z0-9\-]{10,}'
  # Stripe keys
  '[sr]k_live_[A-Za-z0-9]{24,}'
  # Heroku keys
  'heroku_[A-Za-z0-9\-]{36,}'
  # Generic high-entropy strings in quotes (heuristic: 40+ alphanum)
  '["\x27][A-Za-z0-9_\-]{40,}["\x27]'
)

# -------------------------------------------------------------------
# File skip patterns
# -------------------------------------------------------------------
SKIP_DIR_PATTERNS=(
  'node_modules'
  '.git'
  'vendor'
  '__pycache__'
  '.cache'
  'dist'
  'build'
  '.next'
  '.terraform'
)

SKIP_EXTENSIONS=(
  '.png'
  '.jpg'
  '.jpeg'
  '.gif'
  '.bmp'
  '.ico'
  '.svg'
  '.woff'
  '.woff2'
  '.ttf'
  '.eot'
  '.otf'
  '.zip'
  '.gz'
  '.tar'
  '.rar'
  '.7z'
  '.pdf'
  '.doc'
  '.docx'
  '.xls'
  '.xlsx'
  '.ppt'
  '.pptx'
  '.exe'
  '.dll'
  '.so'
  '.dylib'
  '.class'
  '.pyc'
  '.pyo'
  '.o'
  '.a'
  '.wasm'
  '.mp3'
  '.mp4'
  '.avi'
  '.mov'
  '.wav'
  '.flac'
  '.webp'
)

# -------------------------------------------------------------------
# Build grep pattern
# -------------------------------------------------------------------
GREP_PATTERN=''
for i in "${!SECRET_PATTERNS[@]}"; do
  if [ "$i" -gt 0 ]; then
    GREP_PATTERN="${GREP_PATTERN}|"
  fi
  GREP_PATTERN="${GREP_PATTERN}(${SECRET_PATTERNS[$i]})"
done

# -------------------------------------------------------------------
# Collect staged files (excluding deleted, skips, and binaries)
# -------------------------------------------------------------------
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Filter out skipped dirs
filter_files() {
  local files="$1"
  local filtered=""
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    # Skip dirs
    for dir in "${SKIP_DIR_PATTERNS[@]}"; do
      if [[ "$file" == *"$dir"* ]]; then
        continue 2
      fi
    done
    # Skip extensions
    for ext in "${SKIP_EXTENSIONS[@]}"; do
      if [[ "$file" == *"$ext" ]]; then
        continue 2
      fi
    done
    # Skip binary files (check MIME)
    if [ -f "$file" ]; then
      mime=$(file --mime-type -b "$file" 2>/dev/null || echo "unknown")
      if [[ "$mime" == application/x-* ]] || [[ "$mime" == application/octet-stream ]]; then
        continue
      fi
    fi
    filtered="${filtered}${file}"$'\n'
  done <<< "$files"
  echo -n "$filtered"
}

CHECK_FILES=$(filter_files "$STAGED_FILES")

if [ -z "$CHECK_FILES" ]; then
  exit 0
fi

# -------------------------------------------------------------------
# Scan staged content (not working tree) for secrets
# -------------------------------------------------------------------
FOUND_SECRETS=0

while IFS= read -r file; do
  [ -z "$file" ] && continue

  # Get staged content
  content=$(git show ":${file}" 2>/dev/null) || continue

  # Search line by line for pattern matches
  line_num=0
  while IFS= read -r line; do
    line_num=$((line_num + 1))
    for pattern in "${SECRET_PATTERNS[@]}"; do
      if echo "$line" | grep -qE "$pattern" 2>/dev/null; then
        if [ "$FOUND_SECRETS" -eq 0 ]; then
          echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
          echo -e "${RED}║  SECRET DETECTED — commit aborted                         ║${NC}"
          echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
          echo ""
        fi
        # Mask the match for display
        masked=$(echo "$line" | sed -E "s/($pattern)/${YELLOW}[REDACTED]${NC}/g" 2>/dev/null || echo "<secret>")
        echo -e "  ${RED}✗${NC} ${file}:${line_num}  ${masked}" >&2
        FOUND_SECRETS=1
        break  # one hit per line is enough
      fi
    done
  done <<< "$content"
done <<< "$CHECK_FILES"

if [ "$FOUND_SECRETS" -ne 0 ]; then
  echo ""
  echo -e "${YELLOW}To bypass (NOT recommended): git commit --no-verify${NC}"
  echo ""
  exit 1
fi

exit 0
