# Finance PWA environment variables
# Copy to .env.local and fill in your values before running `npm run dev` or `npm run build`.

# API key for the FastAPI backend (header: X-Api-Key).
# This value is embedded in the built JS bundle — do not use a high-value secret here.
# Access is protected at the network level by Cloudflare Access; this key is a secondary check.
VITE_FINANCE_API_KEY=your-api-key-here

# Cloudflare Access service token — allows programmatic API calls to bypass the Access login flow.
# Create at: Cloudflare Zero Trust → Access controls → Service credentials → Service Tokens
# Then add a "Service Auth" policy with this token to the Access application for ro.codingholic.fun.
VITE_CF_ACCESS_CLIENT_ID=your-client-id.access
VITE_CF_ACCESS_CLIENT_SECRET=your-client-secret
